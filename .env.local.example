# Copy to .env.local and fill in.

# --- Lunch form (Resend) ---
# Sign up free at https://resend.com — 3,000 emails/month, no card.
RESEND_API_KEY=

# Optional: override the "from" address. Default is Resend's sandbox sender
# (onboarding@resend.dev), which only delivers to the email that created the
# Resend account. After you verify a domain in Resend, set this to e.g.
# "Steve <hello@yourdomain.com>".
# LUNCH_FROM_EMAIL=

# --- Admin (readings editor) ---
# Password for /admin/login. Pick a long random string.
# Also used to sign the session cookie, so changing it logs you out.
ADMIN_PASSWORD=

# --- Storage for the readings list (Vercel KV / Upstash Redis) ---
# Provision a KV store on Vercel (Storage → Create Database → KV) and these
# vars get auto-injected in production. For local dev you can copy them from
# Vercel's project settings, or skip — the site falls back to the static seed
# list in src/lib/readings.ts when KV is not configured (saves are disabled).
KV_REST_API_URL=
KV_REST_API_TOKEN=
