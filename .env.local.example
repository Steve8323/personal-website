# Copy to .env.local and fill in.
# Sign up free at https://resend.com — you get 3,000 emails/month, no card needed.
# After signing up, create an API key and paste it below.
RESEND_API_KEY=

# Optional: override the "from" address. Default is Resend's onboarding sandbox
# (works without verifying a domain, but only sends to your own verified email).
# Once you verify a domain in Resend, set this to e.g. "Steve <hello@yourdomain.com>".
# LUNCH_FROM_EMAIL=
